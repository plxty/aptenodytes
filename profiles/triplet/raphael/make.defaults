# portage
GENTOO_BINHOST="https://mirrors.tuna.tsinghua.edu.cn/gentoo/releases/amd64/binpackages/23.0/x86-64-v3"

# compiler
CFLAGS="${CFLAGS} -march=znver4"
CXXFLAGS="${CXXFLAGS} -march=znver4"
FCFLAGS="${FCFLAGS} -march=znver4"
FFLAGS="${FFLAGS} -march=znver4"
RUSTFLAGS="${RUSTFLAGS} -C target-cpu=znver4"
