dev-cpp/eigen boost
sys-apps/smartmontools -daemon

# try to be simple:
llvm-runtimes/clang-runtime -compiler-rt -sanitize libcxx
llvm-runtimes/libcxx -clang
llvm-runtimes/libcxxabi -clang

# the extra tools like clangd requires apple blocks extension...
# if you want, you might need
# > llvm-core/clang +extra compiler-clang
# in the system-wide package.use, then re-emerge the clang to make it work.
llvm-core/clang -extra
